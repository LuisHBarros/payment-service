{
  "schemaVersion": 39,
  "version": 1,
  "uid": "payment-business-senior",
  "title": "Payment Service — Senior Production Dashboard",
  "tags": ["payment", "production", "sre", "business"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Business KPIs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(sum(rate(payment_transfers_completed_total[5m])) / clamp_min(sum(rate(payment_transfers_created_total[5m])), 0.001)) or vector(1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.98 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failure Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(sum(rate(payment_transfers_failed_total[5m])) / clamp_min(sum(rate(payment_transfers_created_total[5m])), 0.001)) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.02 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Transferred Volume (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(payment_transfers_amount_sum[1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBRL"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "SLO Burn Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "((sum(rate(payment_transfers_failed_total[5m])) / clamp_min(sum(rate(payment_transfers_created_total[5m])), 0.001)) / 0.001) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Transfers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Creation vs Completion",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(payment_transfers_created_total[5m]))",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "expr": "sum(rate(payment_transfers_completed_total[5m]))",
          "legendFormat": "completed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failures by Reason",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(5, sum by (reason) (rate(payment_transfers_failed_total[5m])))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Outbox Reliability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Outbox Published vs Failed",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(payment_outbox_published_total[5m])) by (event_type)",
          "legendFormat": "published {{event_type}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(payment_outbox_failed_total[5m])) by (event_type)",
          "legendFormat": "failed {{event_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Outbox P95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(payment_outbox_latency_seconds_bucket[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Users",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 13,
      "type": "piechart",
      "title": "Users by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(payment_users_created_total) by (type)",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "User Growth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(payment_users_created_total[5m]))",
          "legendFormat": "users/sec",
          "refId": "A"
        }
      ]
    }
  ]
}